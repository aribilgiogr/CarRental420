@model Core.Concretes.DTOs.Insurance.CreateInsuranceDTO
@{
    ViewData["Title"] = "Yeni Sigorta Poliçesi Ekle";
}

<div class="row">
    <div class="col-xl-8 col-lg-10 mx-auto">
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Yeni Sigorta Poliçesi</h5>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label" asp-for="Name">Poliçe Adı</label>
                        <div class="col-sm-9">
                            <input type="text" class="form-control" asp-for="Name" placeholder="Örn: Tam Kapsamlı Sigorta" required />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label" asp-for="Description">Açıklama</label>
                        <div class="col-sm-9">
                            <textarea class="form-control" asp-for="Description" rows="3" placeholder="Sigorta poliçesinin kısa açıklaması"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label" asp-for="DailyPrice">Günlük Ücret (₺)</label>
                        <div class="col-sm-9">
                            <input type="number" step="0.01" class="form-control" asp-for="DailyPrice" placeholder="0.00" required />
                            <span asp-validation-for="DailyPrice" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label" asp-for="WeeklyPrice">Haftalık Ücret (₺)</label>
                        <div class="col-sm-9">
                            <input type="number" step="0.01" class="form-control" asp-for="WeeklyPrice" placeholder="0.00" />
                            <span asp-validation-for="WeeklyPrice" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label" asp-for="MonthlyPrice">Aylık Ücret (₺)</label>
                        <div class="col-sm-9">
                            <input type="number" step="0.01" class="form-control" asp-for="MonthlyPrice" placeholder="0.00" />
                            <span asp-validation-for="MonthlyPrice" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label" asp-for="CoverageAmount">Kapsam Tutarı (₺)</label>
                        <div class="col-sm-9">
                            <input type="number" step="0.01" class="form-control" asp-for="CoverageAmount" placeholder="Maksimum güvence tutarı" required />
                            <span asp-validation-for="CoverageAmount" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label" asp-for="Deductible">Muafiyet Tutarı (₺)</label>
                        <div class="col-sm-9">
                            <input type="number" class="form-control" asp-for="Deductible" placeholder="Örn: Müşteri sorumluluk payı" required />
                            <span asp-validation-for="Deductible" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label" asp-for="CoverageDetails">Kapsam Detayları</label>
                        <div class="col-sm-9">
                            <textarea class="form-control" asp-for="CoverageDetails" rows="4" placeholder="Lastik, Cam, Far gibi kapsanan veya kapsanmayan durumlar"></textarea>
                            <span asp-validation-for="CoverageDetails" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label" asp-for="IsIncludedByDefault">Varsayılan Mı?</label>
                        <div class="col-sm-9">
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input" type="checkbox" asp-for="IsIncludedByDefault">
                                <label class="form-check-label" asp-for="IsIncludedByDefault">Her kiralamada standart olarak seçili gelsin</label>
                            </div>
                        </div>
                    </div>

                    <div class="row justify-content-end">
                        <div class="col-sm-9">
                            <button type="submit" class="btn btn-primary">Kaydet</button>
                            <a asp-action="Index" class="btn btn-secondary">İptal</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
