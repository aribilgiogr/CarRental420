@model Core.Concretes.DTOs.Location.CreateLocationDTO
@{
    ViewData["Title"] = "Yeni Şube Ekle";
}

<div class="row">
    <div class="col-xl-8 mx-auto">
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Yeni Şube Ekle</h5>
                <small class="text-muted float-end">Tüm alanları doldurmaya özen gösterin</small>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    
                    <h6 class="mb-3">Temel Bilgiler</h6>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Name" class="form-label">Şube Adı</label>
                            <input asp-for="Name" class="form-control" placeholder="Örn: Kadıköy Şube" required />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Manager" class="form-label">Şube Müdürü</label>
                            <input asp-for="Manager" class="form-control" placeholder="Ad Soyad" />
                        </div>
                    </div>

                    <h6 class="mb-3 mt-4">İletişim & Adres</h6>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="City" class="form-label">İl</label>
                            <input asp-for="City" class="form-control" required />
                            <span asp-validation-for="City" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="District" class="form-label">İlçe</label>
                            <input asp-for="District" class="form-control" required />
                            <span asp-validation-for="District" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Street" class="form-label">Açık Adres</label>
                        <textarea asp-for="Street" class="form-control" rows="2" required></textarea>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="PostalCode" class="form-label">Posta Kodu</label>
                            <input asp-for="PostalCode" class="form-control" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="PhoneNumber" class="form-label">Telefon Numarası</label>
                            <input asp-for="PhoneNumber" class="form-control" required />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="Email" class="form-label">E-Posta</label>
                            <input asp-for="Email" type="email" class="form-control" />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Latitude" class="form-label">Enlem (Latitude)</label>
                            <input asp-for="Latitude" type="number" step="any" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Longitude" class="form-label">Boylam (Longitude)</label>
                            <input asp-for="Longitude" type="number" step="any" class="form-control" />
                        </div>
                    </div>

                    <h6 class="mb-3 mt-4">Çalışma Saatleri</h6>
                    <div class="row align-items-center">
                        <div class="col-md-4 mb-3">
                            <label asp-for="OpeningTime" class="form-label">Açılış Saati</label>
                            <input asp-for="OpeningTime" type="time" class="form-control" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="ClosingTime" class="form-label">Kapanış Saati</label>
                            <input asp-for="ClosingTime" type="time" class="form-control" />
                        </div>
                        <div class="col-md-4 mb-3 mt-4">
                            <div class="form-check form-switch mb-2">
                                <input class="form-check-input" type="checkbox" asp-for="IsOpen24Hours" id="isOpen24Hours">
                                <label class="form-check-label" for="isOpen24Hours">7/24 Açık</label>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Notes" class="form-label">Notlar (Opsiyonel)</label>
                        <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                    </div>

                    <button type="submit" class="btn btn-primary">Kaydet</button>
                    <a asp-action="Index" class="btn btn-secondary">İptal</a>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('isOpen24Hours').addEventListener('change', function () {
            var isChecked = this.checked;
            document.getElementById('OpeningTime').disabled = isChecked;
            document.getElementById('ClosingTime').disabled = isChecked;
        });

        // Initialize state on load
        if (document.getElementById('isOpen24Hours').checked) {
            document.getElementById('OpeningTime').disabled = true;
            document.getElementById('ClosingTime').disabled = true;
        }
    </script>
}
