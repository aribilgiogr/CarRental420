@model IEnumerable<Core.Concretes.DTOs.Location.LocationResponseDTO>
@{
    ViewData["Title"] = "Şubeler & Lokasyonlar";
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Tüm Şubeler</h5>
        <a asp-action="Create" class="btn btn-primary">Yeni Şube Ekle</a>
    </div>
    <div class="table-responsive text-nowrap">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Şube Adı</th>
                    <th>Şehir / İlçe</th>
                    <th>İletişim</th>
                    <th>Çalışma Saatleri</th>
                    <th>Durum</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody class="table-border-bottom-0">
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td><strong>@item.Name</strong></td>
                            <td>@item.City / @item.District</td>
                            <td>
                                <div><i class='bx bx-phone'></i> @item.PhoneNumber</div>
                                <div><i class='bx bx-envelope'></i> @item.Email</div>
                            </td>
                            <td>
                                @if (item.IsOpen24Hours)
                                {
                                    <span class="badge bg-label-success">7/24 Açık</span>
                                }
                                else
                                {
                                    <span>@item.OpeningTime.ToString(@"hh\:mm") - @item.ClosingTime.ToString(@"hh\:mm")</span>
                                }
                            </td>
                            <td>
                                @if (item.Active)
                                {
                                    <span class="badge bg-label-primary">Aktif</span>
                                }
                                else
                                {
                                    <span class="badge bg-label-secondary">Pasif</span>
                                }
                            </td>
                            <td>
                                <div class="dropdown">
                                    <button type="button" class="btn p-0 dropdown-toggle hide-arrow" data-bs-toggle="dropdown">
                                        <i class="bx bx-dots-vertical-rounded"></i>
                                    </button>
                                    <div class="dropdown-menu">
                                        <a class="dropdown-item" asp-action="Edit" asp-route-id="@item.Id"><i class="bx bx-edit-alt me-1"></i> Düzenle</a>
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline;" onsubmit="return confirm('Bu şubeyi silmek istediğinize emin misiniz?');">
                                            <button type="submit" class="dropdown-item text-danger"><i class="bx bx-trash me-1"></i> Sil</button>
                                        </form>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center">Henüz bir şube eklenmemiş.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
