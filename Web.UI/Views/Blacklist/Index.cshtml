@model IEnumerable<Core.Concretes.DTOs.Member.MemberResponseDTO>
@{
    ViewData["Title"] = "Kara Liste Yönetimi";
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Kara Listeye Alınan Müşteriler</h5>
    </div>
    <div class="table-responsive text-nowrap">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Müşteri Bilgisi</th>
                    <th>İletişim</th>
                    <th>Kara Liste Tarihi</th>
                    <th>Neden / Açıklama</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody class="table-border-bottom-0">
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <strong>@item.FirstName @item.LastName</strong>
                                <div class="text-muted small">TC: @item.NationalIdNumber</div>
                            </td>
                            <td>
                                <div>@item.Email</div>
                                <div class="text-muted small">@item.PhoneNumber</div>
                            </td>
                            <td>
                                @if (item.BlacklistDate.HasValue)
                                {
                                    <span class="text-danger">@item.BlacklistDate.Value.ToString("dd.MM.yyyy HH:mm")</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                <span class="d-inline-block text-truncate" style="max-width: 250px;" title="@item.BlacklistReason">
                                    @(item.BlacklistReason ?? "Belirtilmemiş")
                                </span>
                            </td>
                            <td>
                                <form asp-action="Unblacklist" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Bu müşteriyi kara listeden çıkarmak istediğinize emin misiniz?');">
                                    <button type="submit" class="btn btn-sm btn-outline-success">
                                        <i class="bx bx-check-circle me-1"></i> Listeden Çıkar
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center">Kara listeye alınmış herhangi bir müşteri bulunamadı.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
