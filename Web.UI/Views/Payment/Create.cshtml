@model Core.Concretes.DTOs.Payment.CreatePaymentDTO
@{
    ViewData["Title"] = "Manuel Ödeme Al";
}

<div class="row">
    <div class="col-xl-8 col-lg-10 mx-auto">
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Manuel Ödeme Al</h5>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label" asp-for="RentalId">Kiralama No</label>
                        <div class="col-sm-9">
                            <input type="number" class="form-control" asp-for="RentalId" placeholder="Örn: 901" required />
                            <span asp-validation-for="RentalId" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label" asp-for="Amount">Ödeme Tutarı (₺)</label>
                        <div class="col-sm-9">
                            <input type="number" step="0.01" class="form-control" asp-for="Amount" required />
                            <span asp-validation-for="Amount" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label" asp-for="PaymentMethod">Ödeme Yöntemi</label>
                        <div class="col-sm-9">
                            <select class="form-select" asp-for="PaymentMethod" required>
                                <option value="">Seçiniz...</option>
                                <option value="Kredi Kartı">Kredi Kartı</option>
                                <option value="Nakit">Nakit</option>
                                <option value="Banka Havalesi">Banka Havalesi (EFT/Havale)</option>
                                <option value="Çek">Çek / Senet</option>
                            </select>
                            <span asp-validation-for="PaymentMethod" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label" asp-for="PaymentStatus">Durum</label>
                        <div class="col-sm-9">
                            <select class="form-select" asp-for="PaymentStatus" required>
                                <option value="Başarılı">Başarılı (Alındı)</option>
                                <option value="Bekliyor">Bekliyor</option>
                                <option value="Başarısız">Başarısız / İptal</option>
                            </select>
                            <span asp-validation-for="PaymentStatus" class="text-danger"></span>
                        </div>
                    </div>
                    
                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label" asp-for="CardLastFourDigits">Kart Son 4 Hanesi (Varsa)</label>
                        <div class="col-sm-9">
                            <input type="text" class="form-control" asp-for="CardLastFourDigits" placeholder="Örn: 1234" maxlength="4" />
                            <span asp-validation-for="CardLastFourDigits" class="text-danger"></span>
                        </div>
                    </div>
                    
                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label" asp-for="InvoiceNumber">Fatura Numarası (İsteğe bağlı)</label>
                        <div class="col-sm-9">
                            <input type="text" class="form-control" asp-for="InvoiceNumber" placeholder="Örn: INV-2026-0001" />
                            <span asp-validation-for="InvoiceNumber" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label" asp-for="Notes">Notlar</label>
                        <div class="col-sm-9">
                            <textarea class="form-control" asp-for="Notes" rows="3" placeholder="Ödeme ile ilgili notlarınız..."></textarea>
                            <span asp-validation-for="Notes" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row justify-content-end">
                        <div class="col-sm-9">
                            <button type="submit" class="btn btn-primary">Kaydet</button>
                            <a asp-action="Index" class="btn btn-secondary">İptal</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
