@model IEnumerable<Core.Concretes.DTOs.Invoice.InvoiceResponseDTO>
@{
    ViewData["Title"] = "Faturalar";
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Kesilen Faturalar</h5>
        <a asp-action="Create" class="btn btn-primary">Manuel Fatura Kes</a>
    </div>
    <div class="table-responsive text-nowrap">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Fatura No / Tarih</th>
                    <th>Kiralama ID</th>
                    <th>Net Tutar (KDV Dahil)</th>
                    <th>Vade / Ödenme Tarihi</th>
                    <th>Durum</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody class="table-border-bottom-0">
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <strong>@item.InvoiceNumber</strong>
                                <div class="text-muted small">@item.InvoiceDate.ToShortDateString()</div>
                            </td>
                            <td><a asp-controller="Rental" asp-action="Details" asp-route-id="@item.RentalId">Kiralama #@item.RentalId</a></td>
                            <td>
                                <div><strong>@item.TotalAmount.ToString("C")</strong></div>
                                <div class="text-muted small">KDV: @item.TaxAmount.ToString("C")</div>
                            </td>
                            <td>
                                @if (item.PaidDate.HasValue)
                                {
                                    <span class="text-success">@item.PaidDate.Value.ToShortDateString() (Ödendi)</span>
                                }
                                else if (item.DueDate.HasValue)
                                {
                                    <span class="text-warning">Son: @item.DueDate.Value.ToShortDateString()</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                @if (item.InvoiceStatus == "Ödendi" || item.InvoiceStatus == "Paid")
                                {
                                    <span class="badge bg-label-success">Ödendi</span>
                                }
                                else if (item.InvoiceStatus == "İptal" || item.InvoiceStatus == "Cancelled")
                                {
                                    <span class="badge bg-label-secondary">İptal Edildi</span>
                                }
                                else
                                {
                                    <span class="badge bg-label-warning">@item.InvoiceStatus</span>
                                }
                            </td>
                            <td>
                                <div class="dropdown">
                                    <button type="button" class="btn p-0 dropdown-toggle hide-arrow" data-bs-toggle="dropdown">
                                        <i class="bx bx-dots-vertical-rounded"></i>
                                    </button>
                                    <div class="dropdown-menu">
                                        @if (item.InvoiceStatus != "Ödendi" && item.InvoiceStatus != "Paid" && item.InvoiceStatus != "İptal")
                                        {
                                            <form asp-action="MarkAsPaid" asp-route-id="@item.Id" method="post" style="display:inline;">
                                                <button type="submit" class="dropdown-item text-success"><i class="bx bx-check-double me-1"></i> Ödendi Olarak İşaretle</button>
                                            </form>
                                        }
                                        <a class="dropdown-item" href="javascript:void(0);"><i class="bx bx-download me-1"></i> PDF İndir</a>
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline;" onsubmit="return confirm('Bu fatura kaydını silmek istediğinize emin misiniz?');">
                                            <button type="submit" class="dropdown-item text-danger"><i class="bx bx-trash me-1"></i> Sil</button>
                                        </form>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center">Kayıtlı fatura bulunamadı.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
