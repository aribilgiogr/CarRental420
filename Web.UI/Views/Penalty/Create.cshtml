@model Core.Concretes.DTOs.Penalty.CreatePenaltyDTO
@{
    ViewData["Title"] = "Yeni Masraf/Ceza Ekle";
}

<div class="row">
    <div class="col-xl-8 mx-auto">
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Masraf / Ceza Detayları</h5>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    
                    <h6 class="mb-3">İlgili Kiralama Bilgileri</h6>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="RentalId" class="form-label">Kiralama Numarası (ID)</label>
                            <select asp-for="RentalId" asp-items="ViewBag.Rentals" class="form-select" required>
                                <option value="">Seçiniz...</option>
                            </select>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="MemberId" class="form-label">Müşteri</label>
                            <select asp-for="MemberId" asp-items="ViewBag.Members" class="form-select" required>
                                <option value="">Seçiniz...</option>
                            </select>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="VehicleId" class="form-label">Araç</label>
                            <select asp-for="VehicleId" asp-items="ViewBag.Vehicles" class="form-select" required>
                                <option value="">Seçiniz...</option>
                            </select>
                        </div>
                    </div>

                    <h6 class="mb-3 mt-4">Masraf Kalemi</h6>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="PenaltyType" class="form-label">Masraf / Ceza Tipi</label>
                            <select asp-for="PenaltyType" class="form-select" required>
                                <option value="Hasar Bedeli">Hasar Bedeli</option>
                                <option value="Geç İade">Geç İade Ücreti</option>
                                <option value="Yakıt Eksikliği">Yakıt Eksikliği Ücreti</option>
                                <option value="Trafik Cezası">Trafik Cezası</option>
                                <option value="Diğer">Diğer</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="PenaltyAmount" class="form-label">Tutar (₺)</label>
                            <input asp-for="PenaltyAmount" type="number" step="0.01" class="form-control" required />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Kısa Açıklama</label>
                        <input asp-for="Description" class="form-control" required />
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="Notes" class="form-label">Ek Notlar (Opsiyonel)</label>
                        <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                    </div>

                    <div class="mt-4">
                        <button type="submit" class="btn btn-primary">Kaydet</button>
                        <a asp-action="Index" class="btn btn-secondary">İptal</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
