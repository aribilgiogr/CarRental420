@model IEnumerable<Core.Concretes.DTOs.Penalty.PenaltyResponseDTO>
@{
    ViewData["Title"] = "Masraf & Ceza Yönetimi";
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Masraf ve Cezalar</h5>
        <a asp-action="Create" class="btn btn-primary">Yeni Masraf Kaydı</a>
    </div>
    <div class="table-responsive text-nowrap">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Masraf Tipi</th>
                    <th>Kiralama Bilgisi</th>
                    <th>Tutar</th>
                    <th>Oluşturulma Tarihi</th>
                    <th>Durum</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody class="table-border-bottom-0">
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <strong>@item.PenaltyType</strong>
                                <div class="text-muted small">@item.Description</div>
                            </td>
                            <td>
                                <div><a asp-controller="Rental" asp-action="Details" asp-route-id="@item.RentalId">Kir. No: @item.RentalId</a></div>
                                <div class="text-muted small">Araç ID: @item.VehicleId</div>
                            </td>
                            <td><strong>@item.PenaltyAmount.ToString("C")</strong></td>
                            <td>
                                @item.CreatedAt.ToShortDateString()
                            </td>
                            <td>
                                @if (item.PenaltyStatus == "Beklemede")
                                {
                                    <span class="badge bg-label-warning">Beklemede</span>
                                }
                                else if (item.PenaltyStatus == "Ödendi")
                                {
                                    <span class="badge bg-label-success">Ödendi</span>
                                }
                                else if (item.PenaltyStatus == "Onaylandı")
                                {
                                    <span class="badge bg-label-primary">Onaylandı</span>
                                }
                                else
                                {
                                    <span class="badge bg-label-secondary">@item.PenaltyStatus</span>
                                }
                            </td>
                            <td>
                                <div class="dropdown">
                                    <button type="button" class="btn p-0 dropdown-toggle hide-arrow" data-bs-toggle="dropdown">
                                        <i class="bx bx-dots-vertical-rounded"></i>
                                    </button>
                                    <div class="dropdown-menu">
                                        @if (item.PenaltyStatus != "Ödendi" && item.PenaltyStatus != "Kaldırıldı")
                                        {
                                            <form asp-action="MarkAsPaid" asp-route-id="@item.Id" method="post" style="display:inline;">
                                                <button type="submit" class="dropdown-item text-success"><i class="bx bx-check-double me-1"></i> Ödendi İşaretle</button>
                                            </form>
                                        }
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline;" onsubmit="return confirm('Bu kaydı silmek istediğinize emin misiniz?');">
                                            <button type="submit" class="dropdown-item text-danger"><i class="bx bx-trash me-1"></i> Sil</button>
                                        </form>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center">Kayıtlı masraf/ceza bulunamadı.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
