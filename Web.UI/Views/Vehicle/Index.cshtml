@model IEnumerable<Core.Concretes.DTOs.Vehicle.VehicleResponseDTO>
@{
    ViewData["Title"] = "Araçlar";
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Tüm Araçlar</h5>
        <a asp-action="Create" class="btn btn-primary">Yeni Araç Ekle</a>
    </div>
    <div class="table-responsive text-nowrap">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Plaka / Model</th>
                    <th>Yıl / KM</th>
                    <th>Fiyat (Günlük)</th>
                    <th>Kategori / Lokasyon</th>
                    <th>Durum</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody class="table-border-bottom-0">
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <strong>@item.LicensePlate</strong>
                                <div class="text-muted small">@item.Brand @item.Model</div>
                            </td>
                            <td>
                                <div>@item.Year</div>
                                <div class="text-muted small">@item.Kilometers.ToString("N0") km</div>
                            </td>
                            <td>@item.PricePerDay.ToString("C")</td>
                            <td>
                                <!-- Kategori ve Lokasyon id'leri yerine isimlerini göstermek için ViewModel'ler veya DTO join'i kullanılabilir.
                                     Şimdilik ID'ler görünebilir. Geliştirilebilir. -->
                                <div>Kat ID: @item.VehicleCategoryId</div>
                                <div class="text-muted small">Şube ID: @item.LocationId</div>
                            </td>
                            <td>
                                @if (item.Active && item.IsAvailable)
                                {
                                    <span class="badge bg-label-success">Müsait</span>
                                }
                                else if (item.Active && !item.IsAvailable)
                                {
                                    <span class="badge bg-label-warning">Kirada</span>
                                }
                                else
                                {
                                    <span class="badge bg-label-secondary">Pasif</span>
                                }
                            </td>
                            <td>
                                <div class="dropdown">
                                    <button type="button" class="btn p-0 dropdown-toggle hide-arrow" data-bs-toggle="dropdown">
                                        <i class="bx bx-dots-vertical-rounded"></i>
                                    </button>
                                    <div class="dropdown-menu">
                                        <a class="dropdown-item" asp-action="Details" asp-route-id="@item.Id"><i class="bx bx-show me-1"></i> Detaylar</a>
                                        <a class="dropdown-item" asp-action="Edit" asp-route-id="@item.Id"><i class="bx bx-edit-alt me-1"></i> Düzenle</a>
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline;" onsubmit="return confirm('Bu aracı silmek istediğinize emin misiniz?');">
                                            <button type="submit" class="dropdown-item text-danger"><i class="bx bx-trash me-1"></i> Sil</button>
                                        </form>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center">Henüz bir araç eklenmemiş.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
