@model Core.Concretes.DTOs.Rental.CreateRentalDTO
@{
    ViewData["Title"] = "Yeni Kiralama Başlat";
}

<div class="row">
    <div class="col-xl-8 mx-auto">
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Kiralama Formu</h5>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    
                    <h6 class="mb-3">Müşteri ve Araç Seçimi</h6>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="MemberId" class="form-label">Müşteri (Üye)</label>
                            <select asp-for="MemberId" asp-items="ViewBag.Members" class="form-select" required>
                                <option value="">-- Müşteri Seçin --</option>
                            </select>
                            <span asp-validation-for="MemberId" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="VehicleId" class="form-label">Kiralanacak Araç</label>
                            <select asp-for="VehicleId" asp-items="ViewBag.Vehicles" class="form-select" required>
                                <option value="">-- Araç Seçin --</option>
                            </select>
                            <span asp-validation-for="VehicleId" class="text-danger"></span>
                        </div>
                    </div>

                    <h6 class="mb-3 mt-4">Lokasyon ve Tarih</h6>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="StartLocationId" class="form-label">Alış Şubesi</label>
                            <select asp-for="StartLocationId" asp-items="ViewBag.Locations" class="form-select" required>
                                <option value="">-- Alış Şubesi Seçin --</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="EndLocationId" class="form-label">Teslim Şubesi</label>
                            <select asp-for="EndLocationId" asp-items="ViewBag.Locations" class="form-select" required>
                                <option value="">-- Teslim Şubesi Seçin --</option>
                            </select>
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="RentalStartDate" class="form-label">Başlangıç Tarihi</label>
                            <input asp-for="RentalStartDate" type="date" class="form-control" required />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="RentalEndDate" class="form-label">Bitiş Tarihi</label>
                            <input asp-for="RentalEndDate" type="date" class="form-control" required />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="RentalDays" class="form-label">Kiralama Süresi (Gün)</label>
                            <input asp-for="RentalDays" type="number" class="form-control" required />
                        </div>
                    </div>

                    <h6 class="mb-3 mt-4">Fiyatlandırma ve Durum</h6>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="TotalPrice" class="form-label">Toplam Tutar (₺)</label>
                            <input asp-for="TotalPrice" type="number" step="0.01" class="form-control" required />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="DiscountAmount" class="form-label">İndirim (₺)</label>
                            <input asp-for="DiscountAmount" type="number" step="0.01" class="form-control" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="FinalPrice" class="form-label">Ödenecek Net Tutar (₺)</label>
                            <input asp-for="FinalPrice" type="number" step="0.01" class="form-control" />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="StartOdometer" class="form-label">Başlangıç Kilometresi</label>
                            <input asp-for="StartOdometer" type="number" class="form-control" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="RentalStatus" class="form-label">Durum</label>
                            <select asp-for="RentalStatus" class="form-select">
                                <option value="Beklemede">Beklemede (Rezervasyon)</option>
                                <option value="Kirada">Kirada</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Notes" class="form-label">Notlar (Opsiyonel)</label>
                        <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                    </div>

                    <div class="mt-4">
                        <button type="submit" class="btn btn-primary">Kiralamayı Başlat</button>
                        <a asp-action="Index" class="btn btn-secondary">İptal</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
