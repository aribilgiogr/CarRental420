@model Core.Concretes.DTOs.VehicleCategory.CreateVehicleCategoryDTO
@{
    ViewData["Title"] = "Yeni Kategori Ekle";
}

<div class="row">
    <div class="col-xl-8 mx-auto">
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Yeni Kategori Ekle</h5>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    
                    <h6 class="mb-3">Temel Bilgiler</h6>
                    <div class="row">
                        <div class="col-md-12 mb-3">
                            <label asp-for="Name" class="form-label">Kategori Adı</label>
                            <input asp-for="Name" class="form-control" placeholder="Örn: SUV, Sedan" required />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Açıklama</label>
                        <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ImageUrl" class="form-label">Görsel URL (Opsiyonel)</label>
                        <input asp-for="ImageUrl" class="form-control" placeholder="https://..." />
                    </div>

                    <h6 class="mb-3 mt-4">Fiyatlandırma (₺)</h6>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="DailyPrice" class="form-label">Günlük Fiyat</label>
                            <input asp-for="DailyPrice" type="number" step="0.01" class="form-control" required />
                            <span asp-validation-for="DailyPrice" class="text-danger"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="WeeklyPrice" class="form-label">Haftalık Fiyat</label>
                            <input asp-for="WeeklyPrice" type="number" step="0.01" class="form-control" required />
                            <span asp-validation-for="WeeklyPrice" class="text-danger"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="MonthlyPrice" class="form-label">Aylık Fiyat</label>
                            <input asp-for="MonthlyPrice" type="number" step="0.01" class="form-control" required />
                            <span asp-validation-for="MonthlyPrice" class="text-danger"></span>
                        </div>
                    </div>

                    <h6 class="mb-3 mt-4">Kapasite ve Özellikler</h6>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="MaxPassengers" class="form-label">Yolcu Kapasitesi</label>
                            <input asp-for="MaxPassengers" type="number" class="form-control" value="5" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="BaggageCapacity" class="form-label">Bagaj Kapasitesi</label>
                            <input asp-for="BaggageCapacity" type="number" class="form-control" value="3" required />
                        </div>
                    </div>
                    <div class="row mt-2">
                        <div class="col-md-4 mb-3">
                            <div class="form-check form-switch mb-2">
                                <input class="form-check-input" type="checkbox" asp-for="HasAirConditioning" checked>
                                <label class="form-check-label" for="HasAirConditioning">Klima Var</label>
                            </div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <div class="form-check form-switch mb-2">
                                <input class="form-check-input" type="checkbox" asp-for="HasAutomaticTransmission" checked>
                                <label class="form-check-label" for="HasAutomaticTransmission">Otomatik Vites</label>
                            </div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <div class="form-check form-switch mb-2">
                                <input class="form-check-input" type="checkbox" asp-for="HasGPS">
                                <label class="form-check-label" for="HasGPS">GPS Var</label>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4">
                        <button type="submit" class="btn btn-primary">Kaydet</button>
                        <a asp-action="Index" class="btn btn-secondary">İptal</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
