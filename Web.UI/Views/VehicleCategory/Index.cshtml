@model IEnumerable<Core.Concretes.DTOs.VehicleCategory.VehicleCategoryResponseDTO>
@{
    ViewData["Title"] = "Araç Kategorileri";
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Tüm Kategoriler</h5>
        <a asp-action="Create" class="btn btn-primary">Yeni Kategori Ekle</a>
    </div>
    <div class="table-responsive text-nowrap">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Kategori Adı</th>
                    <th>Fiyat (Günlük)</th>
                    <th>Kapasite</th>
                    <th>Özellikler</th>
                    <th>Durum</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody class="table-border-bottom-0">
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td><strong>@item.Name</strong></td>
                            <td>@item.DailyPrice.ToString("C")</td>
                            <td>
                                <div><i class='bx bx-group'></i> @item.MaxPassengers Kişi</div>
                                <div><i class='bx bx-briefcase'></i> @item.BaggageCapacity Bagaj</div>
                            </td>
                            <td>
                                @if (item.HasAirConditioning) { <span class="badge bg-label-info mb-1"><i class='bx bx-wind'></i> Klima</span> }
                                @if (item.HasAutomaticTransmission) { <span class="badge bg-label-info mb-1"><i class='bx bx-slider'></i> Otomatik</span> }
                                @if (item.HasGPS) { <span class="badge bg-label-info mb-1"><i class='bx bx-navigation'></i> GPS</span> }
                            </td>
                            <td>
                                @if (item.Active)
                                {
                                    <span class="badge bg-label-primary">Aktif</span>
                                }
                                else
                                {
                                    <span class="badge bg-label-secondary">Pasif</span>
                                }
                            </td>
                            <td>
                                <div class="dropdown">
                                    <button type="button" class="btn p-0 dropdown-toggle hide-arrow" data-bs-toggle="dropdown">
                                        <i class="bx bx-dots-vertical-rounded"></i>
                                    </button>
                                    <div class="dropdown-menu">
                                        <a class="dropdown-item" asp-action="Edit" asp-route-id="@item.Id"><i class="bx bx-edit-alt me-1"></i> Düzenle</a>
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline;" onsubmit="return confirm('Bu kategoriyi silmek istediğinize emin misiniz?');">
                                            <button type="submit" class="dropdown-item text-danger"><i class="bx bx-trash me-1"></i> Sil</button>
                                        </form>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center">Henüz bir kategori eklenmemiş.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
